{
  "name": "synscript-language-support",
  "displayName": "SynScript - Game Development Language",
  "description": "SynScript language support with syntax highlighting, dual themes, code snippets, linting, and @Operator namespaces for game development with Godot and Cocos2D",
  "version": "0.3.0",
  "publisher": "SynthesisLab",
  "icon": "icon.png",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "synscript",
        "aliases": [
          "SynScript",
          "synscript"
        ],
        "extensions": [
          ".syn"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "synscript",
        "scopeName": "source.syn",
        "path": "./syntaxes/synscript.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "synscript",
        "path": "./snippets/synscript.json"
      }
    ],
    "themes": [
      {
        "label": "SynScript Lab Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/SynScript-Lab-Dark.json"
      },
      {
        "label": "SynScript Lab Light",
        "uiTheme": "vs",
        "path": "./themes/SynScript-Lab-Light.json"
      }
    ],
    "debuggers": [
      {
        "type": "synscript",
        "label": "SynScript Debugger",
        "program": "./debugger/adapter.js",
        "runtime": "node",
        "configurationAttributes": {
          "launch": {
            "required": ["program"],
            "properties": {
              "program": {
                "type": "string",
                "description": "Absolute path to the program (.syn file)"
              },
              "args": {
                "type": "array",
                "description": "Arguments passed to the program",
                "items": {
                  "type": "string"
                },
                "default": []
              },
              "console": {
                "type": "string",
                "enum": ["internalConsole", "integratedTerminal"],
                "default": "integratedTerminal"
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "name": "SynScript: Launch",
            "type": "synscript",
            "request": "launch",
            "program": "${workspaceFolder}/program.syn",
            "console": "integratedTerminal"
          }
        ],
        "configurationSnippets": [
          {
            "label": "SynScript: Launch Program",
            "description": "Launch a SynScript program",
            "body": {
              "name": "SynScript: Launch",
              "type": "synscript",
              "request": "launch",
              "program": "^\"\\${workspaceFolder}/program.syn\"",
              "console": "integratedTerminal"
            }
          }
        ]
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/synthesis-lab/synengine"
  },
  "keywords": [
    "game-development",
    "scripting",
    "python",
    "gamedev"
  ]
}
