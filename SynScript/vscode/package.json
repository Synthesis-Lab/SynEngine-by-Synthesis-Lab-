{
  "name": "synscript-language-support",
  "displayName": "SynScript Language Support",
  "description": "Syntax highlighting and language support for SynScript (.syn) files with State Machine, Signal/Slot events, and @Operator namespaces",
  "version": "0.2.0",
  "publisher": "synthesis-lab",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "synscript",
        "aliases": [
          "SynScript",
          "synscript"
        ],
        "extensions": [
          ".syn"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "synscript",
        "scopeName": "source.syn",
        "path": "./syntaxes/synscript.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "synscript",
        "path": "./snippets/synscript.json"
      }
    ],
    "themes": [
      {
        "label": "SynScript Lab Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/SynScript-Lab-Dark.json"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/synthesis-lab/synengine"
  },
  "keywords": [
    "game-development",
    "scripting",
    "python",
    "gamedev"
  ]
}
