{
  "name": "synscript-language-support",
  "displayName": "SynScript - Game Development Language",
  "description": "SynScript language support with syntax highlighting, dual themes, code snippets, linting, debugger, and @Operator namespaces for game development with Godot and Cocos2D",
  "version": "0.3.2",
  "publisher": "SynthesisLab",
  "author": "Synthesis Lab",
  "main": "./extension.js",
  "icon": "icon.png",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.90.0"
  },
  "activationEvents": [
    "workspaceContains:**/*.syn"
  ],
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "synscript",
        "aliases": [
          "SynScript",
          "synscript"
        ],
        "extensions": [
          ".syn"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "synscript",
        "scopeName": "source.syn",
        "path": "./syntaxes/synscript.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "synscript",
        "path": "./snippets/synscript.json"
      }
    ],
    "themes": [
      {
        "label": "SynScript Lab Modern Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/SynScript-Lab-Modern-Dark.json"
      },
      {
        "label": "SynScript Lab Modern Light",
        "uiTheme": "vs",
        "path": "./themes/SynScript-Lab-Modern-Light.json"
      }
    ],
    "commands": [
      {
        "command": "synscript.debug.start",
        "title": "Hata Ayıklamayı Başlat",
        "category": "SynScript",
        "description": "Mevcut SynScript dosyasında hata ayıklamayı başlat"
      },
      {
        "command": "synscript.run.file",
        "title": "Dosyayı Çalıştır",
        "category": "SynScript",
        "description": "Mevcut SynScript dosyasını çalıştır"
      },
      {
        "command": "synscript.debug.stop",
        "title": "Hata Ayıklamayı Durdur",
        "category": "SynScript",
        "description": "Debugger'ı durdur"
      }
    ],
    "debuggers": [
      {
        "type": "synscript",
        "label": "SynScript Debugger",
        "program": "./debugger/adapter.js",
        "runtime": "node",
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Absolute path to the program (.syn file)"
              },
              "args": {
                "type": "array",
                "description": "Arguments passed to the program",
                "items": {
                  "type": "string"
                },
                "default": []
              },
              "console": {
                "type": "string",
                "enum": [
                  "internalConsole",
                  "integratedTerminal"
                ],
                "default": "integratedTerminal"
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "name": "SynScript: Program Başlat",
            "type": "synscript",
            "request": "launch",
            "program": "${workspaceFolder}/program.syn",
            "args": [],
            "console": "integratedTerminal"
          },
          {
            "name": "SynScript: Mevcut Dosyayı Başlat",
            "type": "synscript",
            "request": "launch",
            "program": "${file}",
            "args": [],
            "console": "integratedTerminal"
          },
          {
            "name": "SynScript: Argümanlarla Başlat",
            "type": "synscript",
            "request": "launch",
            "program": "${workspaceFolder}/game.syn",
            "args": [
              "--debug",
              "--port=8080"
            ],
            "console": "integratedTerminal"
          }
        ],
        "configurationSnippets": [
          {
            "label": "SynScript: Program Başlat",
            "description": "SynScript programını başlat",
            "body": {
              "name": "SynScript: Program Başlat",
              "type": "synscript",
              "request": "launch",
              "program": "${workspaceFolder}/program.syn",
              "console": "integratedTerminal"
            }
          },
          {
            "label": "SynScript: Mevcut Dosyayı Başlat",
            "description": "Mevcut SynScript dosyasını başlat",
            "body": {
              "name": "SynScript: Mevcut Dosyayı Başlat",
              "type": "synscript",
              "request": "launch",
              "program": "${file}",
              "console": "integratedTerminal"
            }
          },
          {
            "label": "SynScript: Argümanlarla Başlat",
            "description": "SynScript programını argümanlarla başlat",
            "body": {
              "name": "SynScript: Argümanlarla Başlat",
              "type": "synscript",
              "request": "launch",
              "program": "${workspaceFolder}/game.syn",
              "args": [
                "--debug",
                "--port=8080"
              ],
              "console": "integratedTerminal"
            }
          }
        ]
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Synthesis-Lab/SynEngine-by-Synthesis-Lab-.git"
  },
  "keywords": [
    "game-development",
    "scripting",
    "python",
    "gamedev"
  ]
}
