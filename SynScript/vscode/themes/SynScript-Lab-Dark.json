{
  "name": "SynScript Lab Dark",
  "type": "dark",
  "colors": {
    "editor.background": "#1e1e1e",
    "editor.foreground": "#d4d4d4",
    "editor.lineNumberColor": "#858585",
    "editor.lineHighlightBackground": "#2d2d30",
    "editor.selectionBackground": "#264f78",
    "editor.findMatchBackground": "#515052",
    "editor.findMatchHighlightBackground": "#3f3f42",
    "editorCursor.foreground": "#d4d4d4",
    "editorWhitespace.foreground": "#3e3e42",
    "editorBracketMatch.background": "#0e639c",
    "editorBracketMatch.border": "#0e639c",
    
    "editorError.foreground": "#f48771",
    "editorWarning.foreground": "#cca700",
    "editorInfo.foreground": "#4fc1ff",
    
    "activityBar.background": "#1e1e1e",
    "activityBar.foreground": "#cccccc",
    "activityBarBadge.background": "#007acc",
    "activityBarBadge.foreground": "#ffffff",
    
    "sideBar.background": "#252526",
    "sideBar.foreground": "#d4d4d4",
    "sideBarTitle.foreground": "#ffffff",
    
    "list.hoverBackground": "#2d2d30",
    "list.activeSelectionBackground": "#094771",
    
    "statusBar.background": "#007acc",
    "statusBar.foreground": "#ffffff",
    "statusBar.debuggingBackground": "#cc6633",
    "statusBar.debuggingForeground": "#ffffff",
    
    "tab.activeBackground": "#1e1e1e",
    "tab.activeForeground": "#cccccc",
    "tab.inactiveBackground": "#2d2d30",
    "tab.inactiveForeground": "#969696",
    "tab.activeBorder": "#007acc",
    
    "input.background": "#3c3c3c",
    "input.foreground": "#cccccc",
    "input.border": "#3c3c3c",
    
    "button.background": "#0e639c",
    "button.foreground": "#ffffff",
    "button.hoverBackground": "#1177bb",
    
    "terminal.background": "#1e1e1e",
    "terminal.foreground": "#cccccc",
    "terminal.ansiBlack": "#000000",
    "terminal.ansiRed": "#cd3131",
    "terminal.ansiGreen": "#0dbc79",
    "terminal.ansiYellow": "#e5e510",
    "terminal.ansiBlue": "#2b91f0",
    "terminal.ansiMagenta": "#bc3fbc",
    "terminal.ansiCyan": "#11a8cd",
    "terminal.ansiWhite": "#e5e5e5"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment"],
      "settings": {
        "foreground": "#6a9955",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": ["string"],
      "settings": {
        "foreground": "#ce9178"
      }
    },
    {
      "name": "String Escape",
      "scope": ["string constant.character.escape"],
      "settings": {
        "foreground": "#d7ba7d"
      }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#b5cea8"
      }
    },
    {
      "name": "Built-in Constants",
      "scope": ["constant.language"],
      "settings": {
        "foreground": "#569cd6",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Keywords",
      "scope": ["keyword"],
      "settings": {
        "foreground": "#569cd6",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Control Flow Keywords",
      "scope": ["keyword.control"],
      "settings": {
        "foreground": "#569cd6",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions",
      "scope": ["entity.name.function"],
      "settings": {
        "foreground": "#dcdcaa",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Variables",
      "scope": ["variable"],
      "settings": {
        "foreground": "#9cdcfe"
      }
    },
    {
      "name": "Support Classes/Types",
      "scope": ["support.class", "support.type"],
      "settings": {
        "foreground": "#4ec9b0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "v0.2: State Keyword",
      "scope": ["keyword.declaration.state", "keyword.state"],
      "settings": {
        "foreground": "#d4a9ff",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "v0.2: Signal Keyword",
      "scope": ["keyword.declaration.signal", "keyword.signal"],
      "settings": {
        "foreground": "#4dd0e1",
        "fontStyle": "bold"
      }
    },
    {
      "name": "v0.2: Signal Binding Operator (=>)",
      "scope": ["keyword.operator.signal-bind"],
      "settings": {
        "foreground": "#4dd0e1",
        "fontStyle": "bold"
      }
    },
    {
      "name": "v0.2: Actor Keyword",
      "scope": ["keyword.declaration.actor", "keyword.actor"],
      "settings": {
        "foreground": "#39ae66",
        "fontStyle": "bold"
      }
    },
    {
      "name": "v0.2: @Operator Namespace",
      "scope": ["keyword.operator.at-namespace"],
      "settings": {
        "foreground": "#ffb74d",
        "fontStyle": "bold"
      }
    },
    {
      "name": "v0.2: @vector Operations",
      "scope": ["keyword.operator.at-vector"],
      "settings": {
        "foreground": "#ffb74d",
        "fontStyle": "bold"
      }
    },
    {
      "name": "v0.2: @math Operations",
      "scope": ["keyword.operator.at-math"],
      "settings": {
        "foreground": "#ffb74d",
        "fontStyle": "bold"
      }
    },
    {
      "name": "v0.2: @color Operations",
      "scope": ["keyword.operator.at-color"],
      "settings": {
        "foreground": "#ffb74d",
        "fontStyle": "bold"
      }
    },
    {
      "name": "v0.2: Async/Await Keywords",
      "scope": ["keyword.async", "keyword.await"],
      "settings": {
        "foreground": "#c586c0",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Type Annotations",
      "scope": ["meta.type.annotation"],
      "settings": {
        "foreground": "#4ec9b0"
      }
    },
    {
      "name": "Decorators",
      "scope": ["meta.decorator"],
      "settings": {
        "foreground": "#dcdcaa",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Meta Blocks - State",
      "scope": ["meta.block.state"],
      "settings": {
        "background": "#2d2a3e"
      }
    },
    {
      "name": "Meta Blocks - Actor",
      "scope": ["meta.block.actor"],
      "settings": {
        "background": "#2d3e2d"
      }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#d4d4d4"
      }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation"],
      "settings": {
        "foreground": "#d4d4d4"
      }
    }
  ]
}
